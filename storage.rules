// =============================================================================
// ChampStep — Cloud Storage rules (DEMO ONLY).
// Deploy with:  firebase deploy --only storage
// =============================================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ---- DEMO rules: open access ----------------------------------------
    match /achievements/{childId}/{filename} {
      allow read, write: if true;
    }
    match /avatars/{childId}/{filename} {
      allow read, write: if true;
    }

    // ---- PRODUCTION rules (uncomment once auth is wired) ----------------
    //
    // match /achievements/{childId}/{filename} {
    //   allow read, write: if request.auth != null
    //     && request.resource.size < 5 * 1024 * 1024  // 5 MB cap
    //     && request.resource.contentType.matches('image/.*');
    // }
    // match /avatars/{childId}/{filename} {
    //   allow read, write: if request.auth != null
    //     && request.resource.size < 2 * 1024 * 1024
    //     && request.resource.contentType.matches('image/.*');
    // }
  }
}
